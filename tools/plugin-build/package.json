{
  "name": "@earthquake/tools-plugin-build",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "default": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "typings": "dist/index.d.mts",
  "files": ["dist/**/*"],
  "dependencies": {
    "@powerlines/plugin-plugin": "catalog:",
    "powerlines": "catalog:"
  },
  "devDependencies": {
    "@powerlines/nx": "catalog:",
    "@types/node": "catalog:"
  },
  "types": "./dist/index.d.cts"
}
