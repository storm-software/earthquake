{
  "name": "@earthquake/rss",
  "version": "0.0.1",
  "type": "module",
  "description": "A package containing a Powerlines React plugin for generating core React runtime functionality.",
  "repository": {
    "type": "github",
    "url": "https://github.com/storm-software/earthquake.git",
    "directory": "packages/rss"
  },
  "homepage": "https://stormsoftware.com",
  "bugs": {
    "url": "https://stormsoftware.com/support",
    "email": "support@stormsoftware.com"
  },
  "author": {
    "name": "Storm Software",
    "email": "contact@stormsoftware.com",
    "url": "https://stormsoftware.com"
  },
  "maintainers": [
    {
      "name": "Storm Software",
      "email": "contact@stormsoftware.com",
      "url": "https://stormsoftware.com"
    }
  ],
  "contributors": [
    {
      "name": "Storm Software",
      "email": "contact@stormsoftware.com",
      "url": "https://stormsoftware.com"
    }
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/storm-software"
  },
  "license": "Apache-2.0",
  "private": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "typings": "dist/index.d.mts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "default": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist/**/*"],
  "keywords": [
    "earthquake",
    "powerlines",
    "powerlines-plugin",
    "storm-software",
    "rss",
    "atom",
    "vite"
  ],
  "dependencies": {
    "@powerlines/plugin-plugin": "catalog:",
    "fast-xml-parser": "catalog:",
    "powerlines": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.cts"
}
