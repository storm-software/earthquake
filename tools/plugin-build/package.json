{
  "name": "@earthquake/tools-plugin-build",
  "version": "0.0.1",
  "private": true,
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./index": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "typings": "dist/index.d.mts",
  "files": [
    "dist/**/*"
  ],
  "dependencies": {
    "@powerlines/plugin-plugin": "catalog:",
    "defu": "catalog:",
    "powerlines": "catalog:"
  },
  "devDependencies": {
    "@powerlines/nx": "catalog:",
    "@types/node": "catalog:"
  }
}
