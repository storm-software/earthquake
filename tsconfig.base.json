{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@powerlines/tsconfig/recommended.json",
  "display": "Earthquake - Monorepo Base",
  "compilerOptions": {
    "incremental": true,
    "composite": true,
    "jsx": "react-jsx",
    "types": ["node"],
