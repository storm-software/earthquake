{
  "extends": "@storm-software/workspace-tools/config/base.json",
  "release": {
    "groups": {
      "packages": {
        "projects": ["packages/*"],
        "projectsRelationship": "independent",
        "releaseTag": {
          "pattern": "{projectName}@{version}"
        }
      }
    }
  },
  "plugins": [
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "typecheck": true,
        "build": false,
        "verboseOutput": false
      }
    },
    "@storm-software/workspace-tools/plugins/typescript",
    "@storm-software/workspace-tools/plugins/typescript/untyped",
    "@storm-software/workspace-tools/plugins/typescript/tsup",
    "@storm-software/workspace-tools/plugins/rust",
    {
      "plugin": "@powerlines/nx/plugin",
      "options": {
        "prepare": {
          "dependsOn": [
            "^build",
            "build-bindings-release",
            "build-bindings-prod",
            "build-bindings-wasi",
            "build-bindings-release-wasi",
            "typecheck"
          ]
        },
        "build": {
          "dependsOn": ["prepare"]
        }
      }
    }
  ],
  "sync": {
    "applyChanges": true,
    "globalGenerators": ["@nx/js:typescript-sync"]
  }
}
